<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base app theme — no action bar -->
    <style name="Theme.MyApplication" parent="android:Theme.DeviceDefault.NoActionBar" />

    <!-- Splash screen theme — shown while app loads -->
    <style name="Theme.MyApplication.Starting" parent="Theme.MyApplication">
        <item name="android:windowSplashScreenBackground" tools:targetApi="31">#012E18</item>
        <item name="android:windowSplashScreenAnimatedIcon" tools:targetApi="31">@drawable/ic_launcher_foreground</item>
    </style>
</resources>
